generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createAt      DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String?
  stripePriceId            String?

  accounts     Account[]
  sessions     Session[]
  transactions Transactions[]
  investments  Investments[]
  wishlist     Wishlist[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transactions {
  id       String   @id @default(cuid())
  name     String
  userId   String
  amount   Float
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt
  date     DateTime
  done     Boolean  @default(false)
  isFixed  Boolean  @default(false)

  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      TransactionCategory
  paymentMethod TransactionPaymentMethod
  type          TransactionType
  essentialType TransactionEssentialType
}

enum TransactionType {
  DEPOSIT
  EXPENSE
}

enum TransactionEssentialType {
  ESSENTIAL
  NOT_ESSENTIAL
  SALARY
}

enum TransactionCategory {
  HOUSING
  TRANSPORTATION
  FOOD
  FAST_FOOD
  ENTERTAINMENT
  PUBLIC_SERVICES
  COMMUNICATIONS
  PERSONAL_CARE
  SHOPPING
  SALARY
  EDUCATION
  DONATIONS_AND_PRESENTS
  SECURITIES
  SUBSCRIPTIONS
  PET
  HEALTH
  HOME_RENOVATION
  OTHER
}

enum TransactionPaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CRIPTO
  BANK_SLIP
  CASH
  PIX
  OTHER
}

model Investments {
  id       String                 @id @default(cuid())
  title    String
  userId   String
  amount   Float
  createAt DateTime               @default(now())
  done     Boolean                @default(false)
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     InvestmentsType
  object   InvestmentsObjectType
}

enum InvestmentsType {
  DEPOSIT
  WITHDRAW
}

enum InvestmentsObjectType {
  EMERGENCY_RESERVE
  RETIREMENT
  GOALS
  OTHER
}

model Wishlist {
  id       String   @id @default(cuid())
  title    String
  userId   String
  amount   Float
  createAt DateTime @default(now())
  done     Boolean  @default(false)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
