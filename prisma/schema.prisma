generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createAt      DateTime  @default(now())
  password      String?
  username      String?   @unique

  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripeSubscriptionStatus String?
  stripePriceId            String?

  accounts    Account[]
  sessions    Session[]
  expenses    Expenses[]
  salary      Salary[]
  investments Investments[]
  wishlist    Wishlist[]
  withdraw    Withdraw[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Expenses {
  id           String       @id @default(cuid())
  title        String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  price        String?
  createAt     DateTime     @default(now())
  updateAt     DateTime     @updatedAt
  doneAt       DateTime?
  isFixed      Boolean      @default(false)
  expiryAt     DateTime?
  categories   Categories[]
  categoriesId String?
}

model Categories {
  id       String     @id @default(uuid())
  title    String
  color    String
  expenses Expenses[]
}

model Salary {
  id       String    @id @default(cuid())
  title    String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  price    String
  createAt DateTime  @default(now())
  isFixed  Boolean   @default(false)
  doneAt   DateTime?
  expiryAt DateTime
}

model Investments {
  id       String   @id @default(cuid())
  title    String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  price    String
  createAt DateTime @default(now())

  doneAt DateTime?
}

model Withdraw {
  id       String    @id @default(cuid())
  title    String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  price    String
  createAt DateTime  @default(now())
  doneAt   DateTime?
}

model Wishlist {
  id       String    @id @default(cuid())
  title    String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  price    String
  createAt DateTime  @default(now())
  doneAt   DateTime?
}
